<Window x:Class="工业设备日志_AI_分析小工具.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="工业设备日志 AI 分析小工具"
        Height="820"
        Width="1200"
        MinHeight="650"
        MinWidth="980"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7"
        TextElement.FontSize="14"
        TextElement.FontWeight="Regular"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">
    <Window.Resources>
        <Style x:Key="BrandButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="#0052CC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,6" />
        </Style>
        <Style x:Key="SoftButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Padding" Value="12,6" />
        </Style>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="16" Opacity="0.15" ShadowDepth="2" Color="#1B2740" />
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="18" CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="6" Background="#0052CC" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Factory" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="工业设备日志 AI 分析" />
                        <TextBlock Foreground="#607080" Text="工业 HMI 诊断工作台" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,0" Padding="16" CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ImportLogButton" Grid.Column="0" Height="38" Content="导入日志" Style="{StaticResource SoftButtonStyle}" Click="ImportLogButton_Click" />
                    <Button x:Name="AnalyzeButton" Grid.Column="2" Height="38" Content="AI 故障分析" Style="{StaticResource BrandButtonStyle}" Click="AnalyzeButton_Click" />
                    <Button x:Name="ExportReportButton" Grid.Column="4" Height="38" Content="导出报告" Style="{StaticResource SoftButtonStyle}" Click="ExportReportButton_Click" IsEnabled="False" />

                    <TextBlock x:Name="ParseInfoTextBlock"
                               Grid.Column="6"
                               VerticalAlignment="Center"
                               Foreground="#4A5F79"
                               Text="未导入日志"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox x:Name="ApiBaseUrlTextBox"
                             Grid.Column="0"
                             Grid.Row="0"
                             ToolTip="示例：https://api.deepseek.com（推荐）；按输入原样保存，内部调用会自动拼接 chat/completions"
                             materialDesign:HintAssist.HelperText="请输入有效的 http/https 地址"
                             materialDesign:HintAssist.Hint="https://api.deepseek.com" TextChanged="ApiBaseUrlTextBox_TextChanged" />

                    <TextBox x:Name="ModelNameTextBox"
                             Grid.Column="2"
                             Grid.Row="0"
                             ToolTip="示例：deepseek-v4-flash"
                             materialDesign:HintAssist.HelperText="模型名不能为空"
                             materialDesign:HintAssist.Hint="deepseek-v4-flash" TextChanged="ModelNameTextBox_TextChanged" />

                    <StackPanel Grid.Column="0" Grid.Row="2">
                        <PasswordBox x:Name="ApiKeyPasswordBox"
                                     materialDesign:HintAssist.Hint="API Key（留空不修改）"
                                     ToolTip="API Key：已保存时可留空，不修改" />
                        <TextBlock x:Name="ApiKeyHintTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="#6C8099"
                                   Text="API Key：已保存，留空不修改" />
                    </StackPanel>

                    <Button x:Name="SaveModelSettingsButton"
                            Grid.Column="4"
                            Grid.Row="0"
                            Grid.RowSpan="3"
                            Height="38"
                            Content="保存配置"
                            Style="{StaticResource BrandButtonStyle}"
                            Click="SaveModelSettingsButton_Click" />

                    <TextBlock x:Name="ModelSettingsValidationTextBlock"
                               Grid.Column="0"
                               Grid.Row="3"
                               Grid.ColumnSpan="4"
                               Margin="0,8,0,0"
                               Foreground="#D32F2F"
                               Visibility="Collapsed" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--<Border Grid.Column="0" Padding="12" CornerRadius="10" Background="{DynamicResource MaterialDesignPaper}" Effect="{StaticResource CardShadow}">-->
            <Border Grid.Column="0" Padding="12" CornerRadius="10" Background="Transparent" BorderBrush="#D9E2EE" BorderThickness="1" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="原始日志" />
                    <TextBox x:Name="RawLogTextBox"
                             Grid.Row="1"
                             Margin="0,10,0,0"
                             FontFamily="Consolas"
                             FontSize="13"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="False"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             Background="#F7FAFF"
                             BorderBrush="#D9E2EE"
                             BorderThickness="1"
                             TextWrapping="NoWrap" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="12" CornerRadius="10" Background="Transparent" BorderBrush="#D9E2EE" BorderThickness="1" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="AI 分析报告" />
                    <WebBrowser x:Name="AnalysisMarkdownBrowser"
                                Grid.Row="1"
                                Margin="0,10,0,0" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="StatusBorder" Grid.Row="3" Padding="12" CornerRadius="10" Background="#E8F1FF" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="InfoLamp" Width="10" Height="10" Fill="#1E88E5" Stroke="#155A99" StrokeThickness="0.8" />
                    <TextBlock Margin="5,0,12,0" VerticalAlignment="Center" Text="运行" Foreground="#2F4A67" />

                    <Ellipse x:Name="SuccessLamp" Width="10" Height="10" Fill="#B0BEC5" Stroke="#7A8C9A" StrokeThickness="0.8" />
                    <TextBlock Margin="5,0,12,0" VerticalAlignment="Center" Text="完成" Foreground="#2F4A67" />

                    <Ellipse x:Name="WarningLamp" Width="10" Height="10" Fill="#B0BEC5" Stroke="#7A8C9A" StrokeThickness="0.8" />
                    <TextBlock Margin="5,0,12,0" VerticalAlignment="Center" Text="告警" Foreground="#2F4A67" />

                    <Ellipse x:Name="ErrorLamp" Width="10" Height="10" Fill="#B0BEC5" Stroke="#7A8C9A" StrokeThickness="0.8" />
                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="故障" Foreground="#2F4A67" />
                </StackPanel>

                <TextBlock Grid.Column="2" x:Name="StatusTextBlock" VerticalAlignment="Center" Text="就绪" />
            </Grid>
        </Border>
    </Grid>
</Window>
